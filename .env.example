# ─── Frontend (Vite) ─────────────────────────────────────
# Google OAuth Client ID (Google Cloud Console에서 발급)
VITE_GOOGLE_CLIENT_ID=492131018517-vv1p2c8es475flpd2ofnmhtjmt42sl2o.apps.googleusercontent.com

# Kakao App Key (Kakao Developers에서 발급)
VITE_KAKAO_APP_KEY=0fb4653db1e14f313d4fe3bdeaaec87a

# ─── Backend (server/.env) ───────────────────────────────
# JWT 서명 키 (임의의 긴 문자열)
JWT_SECRET=your-super-secret-jwt-key-change-this

# 앱 URL (이메일 인증 링크 생성에 사용)
APP_URL=http://localhost:3000

# 이메일 (SMTP) 설정 - 설정하지 않으면 콘솔에 인증 링크 출력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password   # Gmail 앱 비밀번호

# Kakao REST API Key
KAKAO_APP_KEY=ecf83ea90df10c37c2698bf89bc5d9c6
