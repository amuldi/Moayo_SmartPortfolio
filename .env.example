# Frontend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_NAVER_CLIENT_ID=your-naver-client-id

# Backend
JWT_SECRET=replace-with-a-unique-32-plus-character-secret
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/moayo

# Optional OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
KAKAO_APP_KEY=your-kakao-rest-api-key

# Optional SMTP. Required in production if email/password signup is enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Optional market data / realtime
FINNHUB_API_KEY=your-finnhub-key
VITE_ENABLE_REALTIME_WS=false

# Optional distributed rate limiting for Vercel / multi-instance production.
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional error tracking
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
