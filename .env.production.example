# Vercel production
APP_URL=https://moayo-smartportfolio.vercel.app
ALLOWED_ORIGINS=https://moayo-smartportfolio.vercel.app
DATABASE_URL=postgresql://user:password@host:5432/moayo
JWT_SECRET=replace-with-a-unique-32-plus-character-secret

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NAVER_CLIENT_ID=your-naver-client-id
VITE_NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Dedicated realtime service
VITE_ENABLE_REALTIME_WS=true
VITE_REALTIME_WS_URL=wss://your-moayo-realtime.example.com/ws
REALTIME_WS_URL=wss://your-moayo-realtime.example.com/ws

# Dedicated realtime server environment
FINNHUB_API_KEY=your-finnhub-key
REALTIME_PORT=4100
REALTIME_WS_PATH=/ws
REALTIME_ALLOWED_ORIGINS=https://moayo-smartportfolio.vercel.app

# Optional production hardening
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
